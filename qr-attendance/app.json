{
  "expo": {
    "name": "QR Attendance Scanner",
    "slug": "qr-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qr-attendance",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f4f8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.qrattendance.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes for attendance tracking.",
        "NSPhotoLibraryUsageDescription": "Photo library access to pick images if needed."
      }
    },
    "android": {
      "package": "com.qrattendance.app",
      "versionCode": 1,
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0d1b2a"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan QR codes for attendance tracking."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
